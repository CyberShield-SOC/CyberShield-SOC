POSTGRES_DB=cybershield
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://replace_me:replace_me@localhost:5432/cybershield
AUTH_SESSION_TTL_MINUTES=60
AUTH_REMEMBER_TTL_DAYS=7
AUTH_COOKIE_SECURE=false

# JWT access tokens. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace_me_with_a_long_random_value
JWT_ACCESS_TTL_MINUTES=10

# Optional first admin user for `python -m app.db.seed` from backend/
CYBERSHIELD_ADMIN_USERNAME=admin
CYBERSHIELD_ADMIN_EMAIL=admin@cybershield.io
CYBERSHIELD_ADMIN_PASSWORD=replace_me_with_a_strong_password
